{
  "name": "openclaw-kit",
  "version": "0.1.0",
  "description": "Operational core for OpenClaw deployments.",
  "license": "MIT",
  "install": {
    "defaultTarget": "~/.openclaw",
    "preserveExisting": true,
    "dryRunByDefault": true
  },
  "layout": {
    "rules": "rules/",
    "skills": "skills/",
    "templates": "templates/",
    "docs": "docs/"
  },
  "exclusions": [
    ".omx/",
    "remote-artifacts/",
    "remote-openclaw-inspect/",
    "remote-openclaw-patches/",
    "jarvis-openclaw-fixes/",
    "openclaw-remote-work/",
    "**/__pycache__/",
    "**/*.pyc",
    "**/*.secret",
    "**/*.token",
    "**/*posts-database.json",
    "**/*profile-posts-scan*",
    "**/*viral-queue*"
  ]
}

