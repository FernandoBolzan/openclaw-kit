{
  "name": "openclaw-kit",
  "version": "0.1.1",
  "description": "Operational core for OpenClaw deployments: rules, routing, validation, recovery, observability, and safe install primitives.",
  "license": "MIT",
  "install": {
    "defaultTarget": "~/.openclaw",
    "preserveExisting": true,
    "dryRunByDefault": true,
    "installPaths": {
      "rules": "rules",
      "skills": "skills",
      "tools": "tools",
      "bin": "bin",
      "config": "config",
      "docs": "docs",
      "systemd": "systemd",
      "cron": "cron"
    }
  },
  "layout": {
    "rules": "rules/",
    "skills": "skills/",
    "templates": "templates/",
    "docs": "docs/",
    "tools": "tools/"
  },
  "exclusions": [
    ".omx/",
    "remote-artifacts/",
    "remote-openclaw-inspect/",
    "remote-openclaw-patches/",
    "jarvis-openclaw-fixes/",
    "openclaw-remote-work/",
    "**/__pycache__/",
    "**/*.pyc",
    "**/*.secret",
    "**/*.token",
    "**/*posts-database.json",
    "**/*profile-posts-scan*",
    "**/*viral-queue*",
    "**/*state.json",
    "**/*backup*"
  ]
}
