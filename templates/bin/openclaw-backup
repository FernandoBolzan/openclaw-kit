#!/usr/bin/env bash
set -euo pipefail

OPENCLAW_HOME="${OPENCLAW_HOME:-$HOME/.openclaw}"
BACKUP_DIR="${OPENCLAW_BACKUP_DIR:-$OPENCLAW_HOME/backups}"
STAMP="$(date -u +%Y%m%dT%H%M%SZ)"

mkdir -p "$BACKUP_DIR"
tar -czf "$BACKUP_DIR/openclaw-core-$STAMP.tar.gz" \
  -C "$OPENCLAW_HOME" \
  manifest.json rules skills tools config docs 2>/dev/null || true

echo "$BACKUP_DIR/openclaw-core-$STAMP.tar.gz"

