# OpenClaw environment
# Copy this file outside the repository and customize it locally.

OPENCLAW_HOME=$HOME/.openclaw
OPENCLAW_DATA_DIR=$HOME/.openclaw/data
OPENCLAW_LOG_DIR=$HOME/.openclaw/logs
OPENCLAW_CONFIG_DIR=$HOME/.openclaw/config
OPENCLAW_SECRETS_FILE=$HOME/.openclaw/vault/.env.secrets
OPENCLAW_RUNTIME_MODE=local
OPENCLAW_DRY_RUN=1

